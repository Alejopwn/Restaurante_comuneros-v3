<?xml version="1.0" encoding="UTF-8"?>
<launch4jConfig>
  <dontWrapJar>false</dontWrapJar>
  <headerType>gui</headerType>
  <jar>dist/Restaurante_comuneros.jar</jar>
  <outfile>ComunerosPOS.exe</outfile>
  <errTitle>Error al iniciar Comuneros POS</errTitle>
  <cmdLine></cmdLine>
  <chdir>.</chdir>
  <priority>normal</priority>
  <downloadUrl>https://adoptium.net/</downloadUrl>
  <supportUrl>https://github.com/Alejopwn/Restaurante_comuneros-v3</supportUrl>
  <stayAlive>false</stayAlive>
  <restartOnCrash>false</restartOnCrash>
  <manifest></manifest>
  <icon></icon>
  <classPath>
    <mainClass>restaurante.Restaurante</mainClass>
    <cp>librerias/AbsoluteLayout.jar</cp>
    <cp>librerias/itextpdf-5.5.1.jar</cp>
    <cp>librerias/mysql-connector-java-8.0.19.jar</cp>
    <cp>librerias/HikariCP-5.1.0.jar</cp>
    <cp>librerias/slf4j-api-2.0.13.jar</cp>
    <cp>librerias/sqlite-jdbc-3.46.0.0.jar</cp>
    <cp>librerias/flatlaf-3.5.2.jar</cp>
    <cp>librerias/jbcrypt-0.4.jar</cp>
  </classPath>
  <jre>
    <!-- Busca primero un JRE portable en la carpeta local 'jre', si no, usa el del sistema -->
    <path>jre</path>
    <requiresJdk>false</requiresJdk>
    <requires64Bit>true</requires64Bit>
    <minVersion>17</minVersion>
    <maxVersion></maxVersion>
  </jre>
</launch4jConfig>
